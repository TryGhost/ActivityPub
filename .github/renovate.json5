{
  extends: [
    'github>tryghost/renovate-config',
    'docker:pinDigests',
    'docker:disableMajor',
  ],
  // Automerge during EU office hours only (Monday - Thursday, 07:00 - 16:59 UTC)
  // Why? Merging to main ships to production, so we want to avoid automerging when no engineer is online
  //
  // Notes:
  // - this schedule doesn't restrict when the PRs are opened by Renovate, only when they are merged
  // - automerge schedule works only if we're using Renovate automerge over platform automerge (Github)
  platformAutomerge: false,
  automergeSchedule: [
    '* 7-16 * * 1,2,3,4',
  ],
  lockFileMaintenance: {
    enabled: true,
    automerge: true,
  },
  packageRules: [
    {
      matchDatasources: [
        'docker',
      ],
      automerge: true,
    },

    // Group Fedify updates together and require a manual review
    {
      groupName: 'Fedify packages',
      groupSlug: 'fedify',
      automerge: false,
      matchPackageNames: [
        '@fedify/*',
      ]
    },

    // Pin @types/node to the deployed Node runtime major (22.x, see Dockerfile
    // and .nvmrc). Bumping the typings ahead of the runtime lets the compiler
    // accept Node-24-only APIs that won't exist in production. Bump
    // allowedVersions in lockstep when the Node base image is upgraded.
    {
      description: 'Pin @types/node to the deployed Node runtime major',
      matchPackageNames: [
        '@types/node',
      ],
      allowedVersions: '<23',
    },

    // Hold OpenTelemetry on the v1.x track while @sentry/node 8.x is in use.
    // @sentry/node 8.55.2 declares "@opentelemetry/core": "^1.30.1" and pulls
    // the rest of the v1.x peer set; mixing in OTel v2.x SDKs creates two
    // incompatible ReadableSpan/SpanExporter type trees (v2 adds a required
    // `instrumentationScope` field), which breaks `tsc` against
    // src/instrumentation.ts. The experimental exporter line forked at
    // 0.200.0 — versions >=0.200.0 require OTel SDK v2.x. When @sentry/node
    // is upgraded to 10.x (which targets OTel v2.x), lift both rules in
    // lockstep with the SDK bumps.
    {
      description: 'Hold OpenTelemetry stable packages on v1.x (Sentry 8.x compat)',
      matchPackageNames: [
        '@opentelemetry/core',
        '@opentelemetry/resources',
        '@opentelemetry/sdk-trace-base',
      ],
      allowedVersions: '<2.0.0',
    },
    {
      description: 'Hold OpenTelemetry experimental packages on the v1.x-compatible 0.5x track',
      matchPackageNames: [
        '@opentelemetry/exporter-trace-otlp-proto',
      ],
      allowedVersions: '<0.200.0',
    },
  ],
}
