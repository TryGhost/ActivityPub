{
  "name": "activitypub",
  "version": "1.2.6",
  "repository": "git@github.com:TryGhost/ActivityPub.git",
  "author": "Ghost Foundation",
  "license": "MIT",
  "main": "src/app.ts",
  "type": "module",
  "packageManager": "pnpm@10.34.5",
  "scripts": {
    "build": "esbuild src/app.ts --sourcemap --platform=neutral --bundle --packages=external --outfile=dist/app.js",
    "build:dev": "pnpm build --sourcemap=inline",
    "build:watch": "concurrently \"pnpm build:dev --watch\" \"node --inspect=0.0.0.0:9229 --watch dist/app.js\"",
    "predev": "docker compose build migrate fake-gcs",
    "dev": "docker compose up activitypub -d --build",
    "dev:standalone": "docker compose up activitypub nginx -d --build",
    "stop": "docker compose stop",
    "db": "docker compose exec mysql mysql -uroot -proot activitypub",
    "fix": "docker compose down --rmi all activitypub activitypub-testing cucumber-tests nginx",
    "logs": "docker compose logs activitypub -f",
    "wipe-db": "docker compose down -v mysql && docker compose up -d activitypub nginx && echo 'ActivityPub DB wiped. You must restart Ghost'",
    "migration": "docker compose run migrate create",
    "migrate": "docker compose up migrate",
    "test:cucumber": "./dev/docker/cucumber-tests",
    "test": "docker compose run --rm migrate-testing up && docker compose run --rm -v \"$(pwd)/dist:/opt/activitypub/dist\" activitypub-testing  pnpm _test:all && pnpm test:cucumber",
    "_test:types": "tsc --noEmit",
    "test:types": "docker compose run --rm activitypub-testing pnpm _test:types",
    "_test:unit": "vitest run --dir src --coverage --reporter=dot '.unit.test.ts'",
    "test:unit": "docker compose run --rm activitypub-testing pnpm _test:unit",
    "_test:unit:dev": "vitest --dir src --coverage --reporter=dot '.unit.test.ts'",
    "test:unit:dev": "docker compose run --rm activitypub-testing pnpm _test:unit:dev",
    "_test:integration": "vitest run --dir src --coverage --reporter=dot '.integration.test.ts'",
    "test:integration": "docker compose run --rm activitypub-testing pnpm _test:integration",
    "_test:code": "vitest run --dir src --coverage --reporter=dot '.test.ts'",
    "test:code": "docker compose run --rm activitypub-testing pnpm _test:code",
    "_test:all": "pnpm _test:types && pnpm _test:code",
    "test:all": "docker compose run --rm activitypub-testing pnpm _test:all",
    "_test:single": "vitest run --coverage --reporter=dot",
    "test:single": "docker compose run --rm activitypub-testing pnpm _test:single",
    "lint": "biome check",
    "fmt": "biome format --write"
  },
  "files": [
    "src"
  ],
  "devDependencies": {
    "@biomejs/biome": "2.5.3",
    "@cucumber/cucumber": "13.0.0",
    "@faker-js/faker": "10.5.0",
    "@fedify/cli": "2.3.1",
    "@types/html-to-text": "9.0.4",
    "@types/jsonwebtoken": "9.0.10",
    "@types/node": "22.20.1",
    "@types/node-jose": "1.1.13",
    "@types/sanitize-html": "2.16.1",
    "@types/sinon": "22.0.0",
    "@types/uuid": "11.0.0",
    "@vitest/coverage-v8": "4.1.10",
    "concurrently": "10.0.3",
    "esbuild": "0.28.1",
    "nock": "14.0.16",
    "typescript": "7.0.2",
    "vite-tsconfig-paths": "6.1.1",
    "vitest": "4.1.10",
    "wiremock-captain": "4.1.3"
  },
  "dependencies": {
    "@fedify/fedify": "2.3.1",
    "@fedify/hono": "2.3.1",
    "@fedify/redis": "2.3.1",
    "@fedify/vocab": "2.3.1",
    "@fedify/vocab-runtime": "2.3.1",
    "@fedify/webfinger": "2.3.1",
    "@google-cloud/opentelemetry-cloud-trace-exporter": "3.0.0",
    "@google-cloud/opentelemetry-cloud-trace-propagator": "0.21.0",
    "@google-cloud/pubsub": "5.3.1",
    "@google-cloud/storage": "7.21.0",
    "@hono/node-server": "2.0.8",
    "@js-temporal/polyfill": "0.5.1",
    "@logtape/logtape": "2.2.4",
    "@opentelemetry/api": "1.9.1",
    "@opentelemetry/core": "2.9.0",
    "@opentelemetry/exporter-trace-otlp-proto": "0.220.0",
    "@opentelemetry/resources": "2.9.0",
    "@opentelemetry/sdk-trace-base": "2.9.0",
    "@sentry/node": "10.65.0",
    "awilix": "13.0.5",
    "es-toolkit": "1.49.0",
    "hono": "4.12.29",
    "html-to-text": "10.0.0",
    "ioredis": "5.11.1",
    "jsonwebtoken": "9.0.3",
    "knex": "3.3.0",
    "ky": "2.0.2",
    "linkify-html": "4.3.3",
    "linkifyjs": "4.3.3",
    "mysql2": "3.22.6",
    "node-html-parser": "8.0.4",
    "node-jose": "2.2.0",
    "reflect-metadata": "0.2.2",
    "sanitize-html": "2.17.6",
    "sharp": "0.35.3",
    "uuid": "14.0.1",
    "x-forwarded-fetch": "0.2.0",
    "zod": "4.4.3"
  }
}
